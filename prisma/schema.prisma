// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(cuid())
  username     String        @unique
  email        String        @unique
  passwordHash String
  teams        FantasyTeam[]
  leagues      League[]      @relation("LeagueCommissioner")
}

model League {
  id                  String           @id @default(cuid())
  name                String
  inviteCode          String           @unique
  leagueSize          Int              @default(8)
  draftType           String           @default("snake")
  draftFormat         String           @default("normal")
  commissionerId      String
  commissioner        User             @relation("LeagueCommissioner", fields: [commissionerId], references: [id])
  teams               FantasyTeam[]
  isDrafted           Boolean          @default(false)
  draftStartedAt      DateTime?
  currentRound        Int?
  currentPickNumber   Int?
  currentTeamOnClockId String?
  currentTeamOnClock  FantasyTeam?     @relation("LeagueCurrentTeamOnClock", fields: [currentTeamOnClockId], references: [id])
  draftOrderEntries   DraftOrderEntry[]
  draftPicks          DraftPick[]
}

model DraftOrderEntry {
  id           String      @id @default(cuid())
  leagueId     String
  league       League      @relation(fields: [leagueId], references: [id])
  teamId       String
  team         FantasyTeam @relation(fields: [teamId], references: [id])
  pickPosition Int

  @@unique([leagueId, pickPosition])
  @@unique([leagueId, teamId])
}

model DraftPick {
  id              String      @id @default(cuid())
  leagueId        String
  league          League      @relation(fields: [leagueId], references: [id])
  teamId          String
  team            FantasyTeam @relation(fields: [teamId], references: [id])
  round           Int
  overallPick     Int
  slot            String
  playerId        String?
  player          LckPlayer?  @relation(fields: [playerId], references: [id])
  organizationId  String?
  organization    LckOrganization? @relation(fields: [organizationId], references: [id])
  createdAt       DateTime    @default(now())

  @@unique([leagueId, overallPick])
}

model LckOrganization {
  id              String        @id @default(cuid())
  name            String        @unique
  players         LckPlayer[]
  defenseTeams    FantasyTeam[] @relation("DefenseOrganization")
  draftPicks      DraftPick[]
}

model LckPlayer {
  id             String            @id @default(cuid())
  name           String
  role           String
  organizationId String
  organization   LckOrganization   @relation(fields: [organizationId], references: [id])
  topTeams       FantasyTeam[]     @relation("TopPlayer")
  jungleTeams    FantasyTeam[]     @relation("JunglePlayer")
  midTeams       FantasyTeam[]     @relation("MidPlayer")
  botTeams       FantasyTeam[]     @relation("BotPlayer")
  supportTeams   FantasyTeam[]     @relation("SupportPlayer")
  draftPicks     DraftPick[]
}

model FantasyTeam {
  id                 String            @id @default(cuid())
  name               String
  userId             String
  user               User              @relation(fields: [userId], references: [id])
  leagueId           String
  league             League            @relation(fields: [leagueId], references: [id])
  topPlayerId        String?
  topPlayer          LckPlayer?        @relation("TopPlayer", fields: [topPlayerId], references: [id])
  junglePlayerId     String?
  junglePlayer       LckPlayer?        @relation("JunglePlayer", fields: [junglePlayerId], references: [id])
  midPlayerId        String?
  midPlayer          LckPlayer?        @relation("MidPlayer", fields: [midPlayerId], references: [id])
  botPlayerId        String?
  botPlayer          LckPlayer?        @relation("BotPlayer", fields: [botPlayerId], references: [id])
  supportPlayerId    String?
  supportPlayer      LckPlayer?        @relation("SupportPlayer", fields: [supportPlayerId], references: [id])
  defenseOrgId       String?
  defenseOrg         LckOrganization?  @relation("DefenseOrganization", fields: [defenseOrgId], references: [id])
  draftOrderEntries  DraftOrderEntry[]
  clockLeagues       League[]          @relation("LeagueCurrentTeamOnClock")
  draftPicks         DraftPick[]

  @@unique([userId, leagueId])
}
